---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import ModCard from '../components/ModCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allMods = (await getCollection('mods')).filter((m) => !m.data.draft);
const categoryParam = Astro.url.searchParams.get('category');
const categories = [...new Set(allMods.map((m) => m.data.category))].sort();

const mods = categoryParam
  ? allMods.filter((m) => m.data.category === categoryParam)
  : allMods;

mods.sort((a, b) => a.data.name.localeCompare(b.data.name, 'ru'));
---

<BaseLayout title="Моды" description="Справочник по всем модам сборки MyModPack">
  <section class="mb-8">
    <h1 class="mb-2 text-3xl font-bold text-white">Справочник модов</h1>
    <p class="text-slate-400">
      {mods.length} модов · Forge 1.20.1 · Поиск по ключевым словам в шапке · В игре: <code>/wiki</code>
    </p>
  </section>

  <CategoryFilter categories={categories} active={categoryParam ?? 'all'} />

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      mods.map((mod) => (
        <ModCard
          name={mod.data.name}
          modId={mod.data.modId}
          category={mod.data.category}
          href={`${base}mods/${mod.slug}/`}
          tags={mod.data.tags}
        />
      ))
    }
  </div>
</BaseLayout>
