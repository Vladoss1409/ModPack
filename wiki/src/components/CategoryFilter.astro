---
interface Props {
  categories: string[];
  active?: string;
}

const { categories, active = 'all' } = Astro.props;
---

<div class="mb-6 flex flex-wrap gap-2" id="cat-filter" data-active={active}>
  <button type="button" data-cat="all" class="wiki-badge cat-btn">Все</button>
  {
    categories.map((cat) => (
      <button type="button" data-cat={cat} class="wiki-badge cat-btn capitalize">
        {cat}
      </button>
    ))
  }
</div>
