---
import '../styles/global.css';
import SearchBar from '../components/SearchBar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Справочник по модам сборки MyModPack' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} · MyModPack Wiki</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-wiki-border bg-wiki-bg/90 backdrop-blur-md">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-4 px-4 py-3">
        <a href={base} class="flex items-center gap-2 font-semibold text-wiki-glow no-underline hover:text-white">
          <span class="text-xl">📖</span>
          <span>MyModPack Wiki</span>
        </a>
        <nav class="flex flex-wrap gap-3 text-sm">
          <a href={base} class="no-underline">Моды</a>
          <a href={`${base}machines/`} class="no-underline">Механизмы</a>
        </nav>
        <div class="ml-auto w-full sm:w-72">
          <SearchBar />
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-wiki-border py-6 text-center text-sm text-slate-500">
      <p>Forge 1.20.1 · CoopTech · В игре: <code class="text-wiki-accent">/wiki</code></p>
    </footer>
  </body>
</html>
